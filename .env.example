# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadforge?schema=public"

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Optional: used only if you add service-role operations later
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# OpenAI (required for enrichment + message generation)
OPENAI_API_KEY="YOUR_OPENAI_KEY"
OPENAI_ENRICH_MODEL="gpt-4o-mini"
OPENAI_MESSAGE_MODEL="gpt-4o-mini"

# Resend (required for sending emails)
RESEND_API_KEY="YOUR_RESEND_KEY"

# Local dev flags
LEADFORGE_ENABLE_MOCK_PUBLIC_WEB="1"
