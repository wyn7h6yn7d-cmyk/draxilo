# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadforge?schema=public"

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Optional: used only if you add service-role operations later
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Branding / public URL (used for SEO metadata)
NEXT_PUBLIC_SITE_URL="https://draxion.eu"
NEXT_PUBLIC_CONTACT_EMAIL="hello@draxion.eu"

# AI (server-side only)
GEMINI_API_KEY="your_api_key_here"
AI_PROVIDER="google"
AI_MODEL="gemini-3-flash-preview"

# Optional per-use-case overrides (if you want finer control)
# AI_ENRICH_MODEL="gemini-3-flash-preview"
# AI_MESSAGE_MODEL="gemini-3-flash-preview"
# AI_SCORE_MODEL="gemini-3-flash-preview"

# Resend (required for sending emails)
RESEND_API_KEY="YOUR_RESEND_KEY"

# Local dev flags
LEADFORGE_ENABLE_MOCK_PUBLIC_WEB="1"
